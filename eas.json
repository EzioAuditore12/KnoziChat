{
	"cli": {
		"version": ">= 16.13.1",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal",
			"android": {
				"credentialsSource": "local"
			}
		},
		"preview": {
			"distribution": "internal",
			"android": {
				"credentialsSource": "local"
			}
		},
		"production": {
			"autoIncrement": true,
			"android": {
				"credentialsSource": "local"
			}
		}
	},
	"submit": {
		"production": {}
	}
}
